meta {
  name: Start Campaign2
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/campaign/start
  body: none
  auth: bearer
}

auth:bearer {
  token: inerit
}

vars:pre-request {
  baseUrl: http://localhost:5205
}

script:post-response {
  const data = res.getBody();
  bru.setEnvVar("matchId", data.matchId);
}

settings {
  encodeUrl: true
  timeout: 0
}
